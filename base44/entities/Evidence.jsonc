{
  "name": "Evidence",
  "type": "object",
  "properties": {
    "case_id": {
      "type": "string",
      "title": "Fall ID"
    },
    "argument_id": {
      "type": "string",
      "title": "Argument ID"
    },
    "title": {
      "type": "string",
      "title": "Titel"
    },
    "description": {
      "type": "string",
      "title": "Beschreibung"
    },
    "weight": {
      "type": "number",
      "title": "Gewicht manuell (0-10)"
    },
    "ki_weight": {
      "type": "number",
      "title": "Gewicht KI (0-10)"
    },
    "ki_reasoning": {
      "type": "string",
      "title": "KI-Begr\u00fcndung"
    },
    "type": {
      "type": "string",
      "title": "Beweistyp"
    },
    "source": {
      "type": "string",
      "title": "Quelle"
    }
  },
  "required": [
    "case_id",
    "title"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}