{
  "name": "JudgeProfile",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Name"
    },
    "gericht": {
      "type": "string",
      "title": "Gericht"
    },
    "kammer": {
      "type": "string",
      "title": "Kammer / Senat"
    },
    "rechtsgebiet": {
      "type": "string",
      "title": "Rechtsgebiet"
    },
    "klaeger_rate": {
      "type": "number",
      "title": "Kl\u00e4gerquote %"
    },
    "vergleich_rate": {
      "type": "number",
      "title": "Vergleichsrate %"
    },
    "durchschnitt_dauer_monate": {
      "type": "number",
      "title": "\u00d8 Verfahrensdauer (Monate)"
    },
    "urteile_gesamt": {
      "type": "number",
      "title": "Urteile gesamt"
    },
    "stil": {
      "type": "string",
      "title": "Verhandlungsstil",
      "enum": [
        "Kooperativ",
        "Streng",
        "Neutral",
        "Prozessaktiv",
        "Vergleichsorientiert"
      ]
    },
    "bekannt_fuer": {
      "type": "string",
      "title": "Bekannt f\u00fcr"
    },
    "schwerpunkte": {
      "type": "array",
      "title": "Rechtliche Schwerpunkte",
      "items": {
        "type": "string"
      }
    },
    "notizen": {
      "type": "string",
      "title": "Notizen"
    },
    "erfahrungen": {
      "type": "array",
      "title": "Kanzlei-Erfahrungen",
      "items": {
        "type": "object",
        "properties": {
          "datum": {
            "type": "string"
          },
          "autor": {
            "type": "string"
          },
          "fall_kontext": {
            "type": "string"
          },
          "vergleichsbereitschaft": {
            "type": "number"
          },
          "entscheidungsgeschwindigkeit": {
            "type": "number"
          },
          "sachkompetenz": {
            "type": "number"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "ki_analyse": {
      "type": "object",
      "title": "KI-Analyse"
    }
  },
  "required": [
    "name",
    "gericht"
  ]
}